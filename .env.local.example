# ──────────────────────────────────────────────────────────
# Supabase Configuration (NEW key format — 2025+)
# ──────────────────────────────────────────────────────────
# Find these in Supabase Dashboard → Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable key (replaces legacy "anon" key)
# Safe to expose in frontend code. Starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (replaces legacy "service_role" key)
# Server-side only — NEVER expose in frontend. Starts with sb_secret_
SUPABASE_SECRET_KEY=

# ──────────────────────────────────────────────────────────
# Resend Email Configuration
# ──────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month

RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@globaltech.lk

LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────
# Scheduled reminders (cron) — REQUIRED for installment reminders
# ──────────────────────────────────────────────────────────
# Shared secret the external cron (GitHub Actions / cron-job.org) sends in the
# `x-cron-secret` header to authorize /api/cron/installment-reminders.
# Generate one: openssl rand -hex 32
# Also set this in Netlify env, and as a GitHub repo secret (with APP_URL).
CRON_SECRET=replace_with_a_long_random_string
