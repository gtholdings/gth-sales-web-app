# ──────────────────────────────────────────────────────────
# Supabase Configuration (NEW key format — 2025+)
# ──────────────────────────────────────────────────────────
# Find these in Supabase Dashboard → Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable key (replaces legacy "anon" key)
# Safe to expose in frontend code. Starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Secret key (replaces legacy "service_role" key)
# Server-side only — NEVER expose in frontend. Starts with sb_secret_
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────
# Resend Email Configuration
# ──────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month

RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
NOTIFICATION_FROM_EMAIL=noreply@globaltech.lk

# ──────────────────────────────────────────────────────────
# Database Connection (OPTIONAL — only if using direct Postgres)
# ──────────────────────────────────────────────────────────
# The @supabase/supabase-js client uses HTTP/REST, so this is NOT needed
# for the app. Only use if connecting with Prisma, pg, postgres.js, etc.
#
# Use the SESSION POOLER URL (IPv4-compatible, port 5432):
#   Supabase Dashboard → Settings → Database → Connection string → Session mode
#
# DO NOT use the direct connection URL — it's IPv6-only and will fail
# on most networks (Netlify serverless, many ISPs, local dev).
#
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────────────────
# Logging (OPTIONAL)
# ──────────────────────────────────────────────────────────
# Winston log level: error | warn | info | http | verbose | debug | silly
# Defaults to 'debug' in development, 'info' in production.
# Set to 'debug' to see detailed auth/login troubleshooting output.
# LOG_LEVEL=debug
